{
  "name": "mercado-monorepo",
  "version": "1.0.0",
  "description": "Mercado monorepo - Backend e-commerce system",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "prepare": "husky",
    "dev": "pnpm --filter @mercado/backend dev",
    "start": "pnpm --filter @mercado/backend start",
    "build": "pnpm --filter @mercado/backend build",
    "test": "pnpm --filter @mercado/backend test",
    "test:watch": "pnpm --filter @mercado/backend test:watch",
    "test:coverage": "pnpm --filter @mercado/backend test:coverage",
    "test:smoke": "pnpm --filter @mercado/backend test:smoke",
    "test:smoke:build": "pnpm --filter @mercado/backend test:smoke:build",
    "typecheck": "pnpm --filter @mercado/backend typecheck",
    "type-coverage": "pnpm --filter @mercado/backend type-coverage",
    "type-coverage:detail": "pnpm --filter @mercado/backend type-coverage:detail",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint:biome": "biome lint .",
    "lint:biome:fix": "biome lint --write .",
    "lint:eslint": "pnpm --filter @mercado/backend lint:eslint",
    "lint:eslint:fix": "pnpm --filter @mercado/backend lint:eslint:fix",
    "lint": "pnpm run lint:biome && pnpm run lint:eslint",
    "lint:fix": "pnpm run lint:biome:fix && pnpm run lint:eslint:fix",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "spell": "cspell .",
    "spell:fix": "cspell . --fix",
    "secrets": "pnpm --filter @mercado/backend secrets",
    "secrets:baseline": "pnpm --filter @mercado/backend secrets:baseline",
    "secrets:history": "pnpm --filter @mercado/backend secrets:history",
    "sync:contacts": "pnpm --filter @mercado/backend sync:contacts",
    "temporal:worker": "pnpm --filter @mercado/backend temporal:worker",
    "db:generate": "pnpm --filter @mercado/backend db:generate",
    "db:migrate": "pnpm --filter @mercado/backend db:migrate",
    "db:migrate:test": "pnpm --filter @mercado/backend db:migrate:test",
    "db:push": "pnpm --filter @mercado/backend db:push",
    "db:studio": "pnpm --filter @mercado/backend db:studio",
    "db:introspect": "pnpm --filter @mercado/backend db:introspect",
    "db:check": "pnpm --filter @mercado/backend db:check",
    "knip": "pnpm --filter @mercado/backend knip",
    "openapi:generate": "pnpm --filter @mercado/backend openapi:generate",
    "openapi:generate:lint": "pnpm --filter @mercado/backend openapi:generate:lint",
    "openapi:preview": "pnpm --filter @mercado/backend openapi:preview",
    "lint:redocly": "pnpm --filter @mercado/backend lint:redocly"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.7",
    "cspell": "^9.3.2",
    "husky": "^9.1.7"
  },
  "pnpm": {
    "overrides": {
      "esbuild@<=0.24.2": ">=0.25.0",
      "tar-fs@>=2.0.0 <2.1.4": ">=2.1.4",
      "tar-fs@>=3.0.0 <3.1.1": ">=3.1.1"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "@ts-rest/fastify>fastify": "5"
      }
    }
  }
}
