# Environment Configuration Template
# Copy this file to .env and fill in the values

# ============================================================================
# Application
# ============================================================================
NODE_ENV="development"
PORT="3000"
HOST="0.0.0.0"
LOG_LEVEL="info"

# ============================================================================
# Database
# ============================================================================
DATABASE_URL="postgresql://user:password@localhost:5432/accounting_dev"

# ============================================================================
# Security
# ============================================================================
# JWT secret (production only, min 32 characters)
JWT_SECRET="your-secure-jwt-secret-here-minimum-32-chars"

# API Bearer Tokens (comma-separated list)
API_BEARER_TOKENS="token1,token2,token3"

# ============================================================================
# Core Microservice API
# ============================================================================
CORE_API_URL="https://api.example.com"
CORE_API_KEY="your-core-api-key"
CORE_API_TIMEOUT="30000"
CORE_API_RETRY_ATTEMPTS="3"
CORE_API_RETRY_DELAY_MS="1000"

# ============================================================================
# Odoo ERP Integration
# ============================================================================
ODOO_URL="https://odoo.example.com"
ODOO_DATABASE="your-database-name"
ODOO_USERNAME="your-username"
ODOO_API_KEY="your-odoo-api-key"

# ============================================================================
# Temporal Workflow Orchestration
# ============================================================================
TEMPORAL_ADDRESS="localhost:7233"
TEMPORAL_NAMESPACE="default"
TEMPORAL_TASK_QUEUE="default"
TEMPORAL_API_KEY="FAKE_TEMPORAL_API_KEY"

# ============================================================================
# Postmark Email Processing
# ============================================================================
POSTMARK_MAX_ATTACHMENT_SIZE="10485760"        # 10MB
POSTMARK_MAX_TOTAL_ATTACHMENT_SIZE="52428800"  # 50MB

# ============================================================================
# Job Generation Configuration
# ============================================================================
JOB_GENERATION_DUE_OFFSET_DAYS="2"
JOB_GENERATION_DUE_HOUR="17"
JOB_GENERATION_BATCH_SIZE="100"

# ============================================================================
# VIES API Configuration (EU VAT validation)
# ============================================================================
VIES_API_KEY="your-vies-api-key"
VIES_API_BASE_URL="https://api.vatcheckapi.com/v2"
VIES_API_TIMEOUT="30000"
VIES_API_RETRY_ATTEMPTS="2"
VIES_API_RETRY_DELAY_MS="1000"

# ============================================================================
# AWS / LocalStack S3 Configuration
# ============================================================================
# For local development with LocalStack:
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="test"
AWS_SECRET_ACCESS_KEY="test"
S3_ENDPOINT="http://localhost:4566"
S3_BUCKET_NAME="backend-accounting-documents"
S3_FORCE_PATH_STYLE="true"

# For production AWS (remove S3_ENDPOINT and use real credentials):
# AWS_REGION="us-east-1"
# AWS_ACCESS_KEY_ID="your-real-aws-access-key-id"
# AWS_SECRET_ACCESS_KEY="your-real-aws-secret-access-key"
# S3_BUCKET_NAME="your-production-bucket-name"
# S3_FORCE_PATH_STYLE="false"
