{
  "name": "@mercado/backend",
  "version": "1.0.0",
  "description": "Backend e-commerce system built with Node.js, TypeScript, and PostgreSQL",
  "type": "module",
  "main": "dist/src/server.js",
  "scripts": {
    "start": "node dist/src/server.js",
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:smoke": "vitest run --config tests/smoke/vitest.config.smoke.ts",
    "test:smoke:build": "SMOKE_MODE=build vitest run --config tests/smoke/vitest.config.smoke.ts",
    "typecheck": "tsc --noEmit",
    "type-coverage": "type-coverage",
    "type-coverage:detail": "type-coverage --detail",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint:biome": "biome lint .",
    "lint:biome:fix": "biome lint --write .",
    "lint:eslint": "eslint . --max-warnings 0",
    "lint:eslint:fix": "eslint . --fix --max-warnings 0",
    "lint": "pnpm run lint:biome && pnpm run lint:eslint",
    "lint:fix": "pnpm run lint:biome:fix && pnpm run lint:eslint:fix",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "spell": "cspell .",
    "spell:fix": "cspell . --fix",
    "secrets": "gitleaks detect --verbose",
    "secrets:baseline": "gitleaks detect --baseline-path .gitleaks-baseline.json",
    "secrets:history": "gitleaks detect --verbose --log-opts='--all'",
    "sync:contacts": "tsx src/scripts/contacts-sync.ts",
    "temporal:worker": "tsx src/shared/workflows/worker.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:test": "NODE_ENV=test drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:introspect": "drizzle-kit introspect",
    "db:check": "drizzle-kit check",
    "db:seed:products": "tsx src/scripts/seed-products.ts",
    "knip": "knip",
    "openapi:generate": "tsx src/scripts/generate-openapi.ts",
    "openapi:generate:lint": "tsx src/scripts/generate-openapi.ts && sh -c \"redocly lint \\${npm_config_file:-generated/openapi/openapi.json}\"",
    "openapi:preview": "sh -c \"redocly preview-docs \\${npm_config_file:-generated/openapi/openapi.json}\"",
    "lint:redocly": "redocly lint"
  },
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.15.0",
  "typeCoverage": {
    "atLeast": 97,
    "strict": true,
    "ignoreFiles": [
      "dist/**",
      "node_modules/**",
      "**/*.test.ts",
      "tests/**"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@redocly/cli": "^2.12.1",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.48.0",
    "@vitest/coverage-v8": "^4.0.10",
    "drizzle-kit": "^0.31.7",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "knip": "^5.86.0",
    "msw": "^2.12.3",
    "pino-pretty": "^13.1.2",
    "tsx": "^4.20.6",
    "type-coverage": "^2.29.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vitest": "^4.0.8"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.967.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/swagger": "^9.3.0",
    "@fastify/swagger-ui": "^5.2.3",
    "@mercado/api-contracts": "workspace:*",
    "@sentry/node": "^10.30.0",
    "@t3-oss/env-core": "^0.10.1",
    "@temporalio/activity": "^1.13.2",
    "@temporalio/client": "^1.13.2",
    "@temporalio/worker": "^1.13.2",
    "@temporalio/workflow": "^1.13.2",
    "@ts-rest/core": "^3.52.1",
    "@ts-rest/fastify": "^3.52.1",
    "@ts-rest/open-api": "^3.52.1",
    "argon2": "^0.44.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.7",
    "fastify": "^5.6.2",
    "fastify-plugin": "^5.1.0",
    "openapi3-ts": "^4.5.0",
    "pino": "^10.1.0",
    "postgres": "^3.4.7",
    "stripe": "^20.4.0",
    "yaml": "^2.8.2",
    "zod": "^3.25.76"
  }
}
